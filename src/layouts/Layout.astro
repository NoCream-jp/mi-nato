---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
}

const { 
  title = 'mi-nato.com',
  description = 'My portfolio site',
  image = '/brand/ogp-image.png',
  imageAlt = "Minato Hayashi's portfolio site",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogpImageURL = new URL(image, Astro.site).href;
const ogpImageWidth = 1200;
const ogpImageHeight = 630;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- [id].astroで数式レンダリングするための共通レイアウト -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" />
    
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="mi-nato.com" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogpImageURL} />
    <meta property="og:image:secure_url" content={ogpImageURL} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={ogpImageWidth.toString()} />
    <meta property="og:image:height" content={ogpImageHeight.toString()} />
    <meta property="og:image:alt" content={imageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@sXMN1au45a68174" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogpImageURL} />
    <meta name="twitter:image:alt" content={imageAlt} />
    
    <ClientRouter />
  </head>
  <body class="bg-gray-100" transition:animate="fade">
    
    <header class="md:px-0 m-5 flex items-center justify-between px-6">
      <div class="flex items-center gap-5">
        <a href="/" class="hidden text-xl font-normal tracking-wide text-zinc-500 md:block">Minato's homepage</a>
      </div>
      <nav class="flex w-full text-lg font-normal text-zinc-800 gap-10 md:justify-center justify-between md:w-auto">
        <a href="/about"  class="cursor-pointer transition-colors hover:text-gray-500">about</a>
        <a href="/blog" class="cursor-pointer transition-colors hover:text-gray-500">blog</a>
        <a href="/action" class="cursor-pointer transition-colors hover:text-gray-500">action</a>
        <a href="/learning" class="cursor-pointer transition-colors hover:text-gray-500">learning</a>
      </nav>
    </header>
    
    <slot />
    
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
  }
  
  html {
    /* scroll-behavior: smooth; */
  }

  :global(h2) {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 400;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  :global(p) {
    margin-bottom: 0.3rem;
    line-height: 1.5;
  }
  *:focus:not(:focus-visible) {
    outline: none;
  }
</style>