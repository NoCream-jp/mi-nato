---
interface Props {
  href: string;
  description?: string;
}

const { href, description } = Astro.props;
---

<a href={href} class="button-container">
  <div class="button-description">
    {description}
  </div>
  <slot />
</a>

<style>
  .button-container {
    /* サイズ、形 */
    width: fit-content;
    height: fit-content;

    /* デザイン */
    border: 2px solid var(--theme3);
    border-radius: 30px;
    padding: 16px 20px;

    /* コンテンツ */
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;

    color: var(--theme3);
    font-weight: 500;
    font-size: 1rem;
    text-decoration: none;
    cursor: pointer;

    transition: all 0.2s ease;
  }

  .button-container:hover {
    background-color: var(--theme7);
    transform: scale(1.05);
    border-radius: 15px;
  }

  .button-container i {
    font-size: 1.2rem;
    opacity: 0.9;
  }
</style>
