---
interface Props {
  title: string;
  issuer: string;
  date: string;
  description: string;
  link?: string;
  tags?: string[];
}

const {
  title,
  issuer,
  date,
  description,
  link = "#",
  tags = []
} = Astro.props;
---

<div
  class="cert-card cursor-pointer rounded-xl border border-zinc-200 bg-white p-4 transition hover:bg-zinc-50"
  data-tags={tags.join(",")}
  data-title={title}
  data-issuer={issuer}
  data-date={date}
  data-description={description}
  data-link={link}
>
  <h3 class="text-[15px] font-medium">
    {title}
  </h3>

  <p class="text-xs text-zinc-600 mt-1">
    {issuer} / {date}
  </p>
</div>