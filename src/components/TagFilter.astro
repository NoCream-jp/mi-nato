---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2 mb-8">
  <button 
    data-tag="all"
    class="tag-btn px-3 py-1 text-xs rounded-full border border-zinc-300 data-[active=false]:hover:bg-zinc-100 transition"
  >
    All
  </button>

  {tags.map(tag => (
    <button
      data-tag={tag}
      class="tag-btn px-3 py-1 text-xs rounded-full border border-zinc-300 data-[active=false]:hover:bg-zinc-100 transition"
    >
      {tag}
    </button>
  ))}
</div>