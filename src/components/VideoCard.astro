---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props as Props;
---

<div class="video-card group cursor-pointer" data-id={videoId}>
  <div class="relative aspect-video overflow-hidden rounded-xl">
    
    <img
      src={`https://img.youtube.com/vi/${videoId}/hqdefault.jpg`}
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
    />

    <div class="absolute inset-0 flex items-center justify-center transition-colors duration-500">
      
      <button
        class="flex h-[60px] w-[60px] cursor-pointer items-center justify-center rounded-full bg-black/60 pl-1 text-2xl text-white opacity-0 scale-95 transition-all duration-500 ease-out group-hover:opacity-100 group-hover:scale-100"
      >
        ▶
      </button>

    </div>
  </div>
</div>