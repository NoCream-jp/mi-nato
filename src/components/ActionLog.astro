---
import { getCollection } from 'astro:content';

const allLogs = await getCollection('action-log');

const sortedLogs = [...allLogs].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// 3. 年号の境界を判定
const displayLogs = sortedLogs.map((log, index) => {
  const year = log.data.date.getFullYear().toString();
  // 月日のフォーマット（例: "Jun 23" または "6月23日"）
  const monthDay = log.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

  // 前のアイテムと年が違うなら、境界線とみなす
  const prevLog = sortedLogs[index - 1];
  const isNewYear = !prevLog || prevLog.data.date.getFullYear().toString() !== year;

  return {
    ...log,
    year,
    monthDay,
    isNewYear,
  };
});
---

<div class="w-full max-w-2xl mx-auto py-8">
  <div class="relative pl-20 md:pl-28">
    
    <div class="absolute left-20 md:left-28 top-2 bottom-0 w-px bg-zinc-200"></div>

    {displayLogs.map((log) => (
      <div class="relative mb-12 group">
        
        {/* 境界（isNewYear）の時だけ、ツリーの左側に年号を描画 */}
        {log.isNewYear && (
          <div class="absolute right-full mr-6 md:mr-10 top-0">
            <span class="text-xl md:text-lg font-light tracking-widest text-zinc-300">
              {log.year}
            </span>
          </div>
        )}

        {/* ツリーのドット（線の真上に来るように -left で微調整） */}
        <span aria-hidden="true" class="absolute flex items-center justify-center w-2.5 h-2.5 bg-zinc-300 rounded-full left-[-4.5px] top-1.5 ring-4 ring-white transition-all duration-300 group-hover:bg-zinc-800 group-hover:scale-110"></span>
        
        {/* 右側のコンテンツエリア */}
        <div class="pl-8">
          <div class="flex flex-col md:flex-row md:items-baseline gap-2 mb-1">
            <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-black">
              {log.data.title}
            </h3>
          </div>
          
          <time class="block mb-3 text-sm font-normal text-zinc-400">
            {log.monthDay}
          </time>
          
          <p class="text-[15px] text-zinc-600 leading-relaxed">
            {log.data.description}
          </p>
        </div>

      </div>
    ))}
  </div>
</div>