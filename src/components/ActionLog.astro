---
import { getCollection, render } from 'astro:content';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

const allLogs = await getCollection('action-log');

let sortedLogs = [...allLogs].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

if (limit) {
  sortedLogs = sortedLogs.slice(0, limit);
}

const displayLogs = sortedLogs.map((log, index) => {
  const year = log.data.date.getFullYear().toString();
  const monthDay = log.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

  // 前のアイテムと比較（その年の最初かどうか）
  const prevLog = sortedLogs[index - 1];
  const isFirstOfYear = !prevLog || prevLog.data.date.getFullYear().toString() !== year;

  // 【追加】次のアイテムと比較（その年の最後かどうか）
  const nextLog = sortedLogs[index + 1];
  const isLastOfYear = !nextLog || nextLog.data.date.getFullYear().toString() !== year;

  return {
    data: log.data,
    year,
    monthDay,
    isFirstOfYear,
    isLastOfYear, // テンプレートに渡す
    originalEntry: log,
  };
});
---

<div class="w-full max-w-2xl mx-auto">
  <div class="relative pl-8">
    {await Promise.all(displayLogs.map(async (log) => {
      const { Content } = await render(log.originalEntry);

      return (
        <div class="w-full">
          {/* 年が変わるタイミングのバッジと区切りの余白 */}
          {log.isFirstOfYear && (
            <div class="relative flex items-center mb-5 mt-10 first:mt-0 group z-10">
              <div class="absolute -left-4 flex items-center justify-center bg-white py-2 -translate-x-1/2">
                <span class="inline-block px-3 py-1 text-md font-semibold tracking-widest text-zinc-600">
                  {log.year}
                </span>
              </div>
            </div>
          )}

          <div class="relative mb-8 group">
            
            {/* 【修正】線の長さを動的に切り替え */}
            {/* isLastOfYearがtrueなら bottom-0 で止め、falseなら -bottom-8 で次のドットまで繋ぐ */}
            <div class={`absolute -left-4 top-3 w-px bg-zinc-200 -translate-x-1/2 ${log.isLastOfYear ? 'bottom-0' : '-bottom-10'}`}></div>
            
            {/* ドット（丸いインジケーター） */}
            <span aria-hidden="true" class="absolute flex items-center justify-center w-2.5 h-2.5 bg-zinc-300 rounded-full -left-4 top-1.5 -translate-x-1/2 ring-4 ring-white transition-all duration-300"></span>
            
            <div>
              <div class="flex flex-col md:flex-row md:items-baseline gap-2 mb-1">
                <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-black">
                  {log.data.title}
                </h3>
              </div>
              
              <time class="block mb-2 text-sm font-normal text-zinc-400">
                {log.monthDay}
              </time>
              
              <div class="text-[13px] text-zinc-600 leading-relaxed">
                {log.data.description && (
                  <p class="mb-2">{log.data.description}</p>
                )}
                
                <div class="prose prose-zinc prose-sm max-w-none">
                  <Content />
                </div>
              </div>
            </div>
          </div>
        </div>
      );
    }))}
  </div>
</div>