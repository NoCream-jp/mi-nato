---
import { getCollection, render } from 'astro:content';

interface Props {
  limit?: number;
}

const { limit } = Astro.props;

const allLogs = await getCollection('action-log');

let sortedLogs = [...allLogs].sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

if (limit) {
  sortedLogs = sortedLogs.slice(0, limit);
}

const displayLogs = sortedLogs.map((log, index) => {
  const year = log.data.date.getFullYear().toString();
  // 月日のフォーマット（例: "Jun 23" または "6月23日"）
  const monthDay = log.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

  // 前のアイテムと年が違うなら、境界線とみなす
  const prevLog = sortedLogs[index - 1];
  const isNewYear = !prevLog || prevLog.data.date.getFullYear().toString() !== year;

  return {
    data: log.data,
    year,
    monthDay,
    isNewYear,
    originalEntry: log, // 元のコレクションエントリを保持
  };
});
---

<div class="w-full max-w-2xl mx-auto py-8">
  <div class="relative pl-20 md:pl-18">

    {/* タイムラインの縦線。ログがある場合のみ表示 */}
    {displayLogs.length > 0 && <div class="absolute left-20 md:left-18 top-2 bottom-0 w-px bg-zinc-200"></div>}
    
    {/* Promise.all を使って非同期処理を解決してからレンダリング */}
    {await Promise.all(displayLogs.map(async (log) => {
      const { Content } = await render(log.originalEntry);

      return (
        <div class="relative mb-12 group">
          
          {/* 境界（isNewYear）の時だけ、ツリーの左側に年号を描画 */}
          {log.isNewYear && (
            <div class="absolute right-full mr-3 top-[-2px]">
              <span class="text-md font-normal tracking-widest text-zinc-500">
                {log.year}
              </span>
            </div>
          )}

          {/* ツリーのドット */}
          <span aria-hidden="true" class="absolute flex items-center justify-center w-2.5 h-2.5 bg-zinc-300 rounded-full left-[-4.5px] top-1.5 ring-4 ring-white transition-all duration-300 "></span>
          
          {/* 右側のコンテンツエリア */}
          <div class="pl-8">
            <div class="flex flex-col md:flex-row md:items-baseline gap-2 mb-1">
              <h3 class="text-base font-medium text-zinc-900 transition-colors group-hover:text-black">
                {log.data.title}
              </h3>
            </div>
            
            <time class="block mb-3 text-sm font-normal text-zinc-400">
              {log.monthDay}
            </time>
            
            <div class="text-[15px] text-zinc-600 leading-relaxed">
              {/* フロントマターの description を表示（あれば） */}
              {log.data.description && (
                <p class="mb-4">{log.data.description}</p>
              )}
              
              {/* ここに Markdown の本文が出力される */}
              <div class="prose prose-zinc prose-sm max-w-none">
                <Content />
              </div>
            </div>
          </div>
        </div>
      );
    }))}
  </div>
</div>