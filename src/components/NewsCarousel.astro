---
// src/components/NewsCarousel.astro
import { getCollection } from 'astro:content';

// ニュースを取得し、日付が新しい順にソートして、最新の5件だけを切り出す
const allNews = await getCollection('news');
const recentNews = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<div class="news-carousel-wrapper">
  <div class="carousel-scroll-container">
    {
      recentNews.map((news) => (
        <a href={news.data.href || '#'} class="news-card">
          <div class="news-header">
            {news.data.badge && (
              <span class="news-badge">{news.data.badge}</span>
            )}
            <span class="news-date">
              {news.data.date.toLocaleDateString('ja-JP', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
              })}
            </span>
          </div>
          <h3 class="news-title">{news.data.title}</h3>

          <div class="news-icon">
            <i class="fa-solid fa-arrow-right" />
          </div>
        </a>
      ))
    }
  </div>
</div>

<style>
  .news-carousel-wrapper {
    width: 100%;
    /* カードのホバー時の影が見切れないように上下に少し余白を持たせる */
    padding: 16px 0;
  }

  .carousel-scroll-container {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    padding: 0 16px; /* 両端の余白 */

    /* ★魔法のプロパティ：スクロール時にカード単位でピタッと止まる */
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;

    /* スクロールバーを隠す（モダンなUIのため） */
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .carousel-scroll-container::-webkit-scrollbar {
    display: none;
  }

  .news-card {
    /* ★魔法のプロパティ：画面幅の80%にして、次のカードが少し見切れるようにする（スワイプの誘発） */
    flex: 0 0 85%;
    max-width: 320px;
    scroll-snap-align: center; /* 中央でピタッと止まる */

    display: flex;
    flex-direction: column;
    text-decoration: none;

    /* M3のスタイリング (青基調) */
    background-color: #f0f4f8; /* 非常に薄い青（Surface Container） */
    border-radius: 24px;
    padding: 24px;
    color: #1a1c1e;

    /* 柔らかいアニメーション */
    transition:
      transform 0.2s cubic-bezier(0.2, 0, 0, 1),
      box-shadow 0.2s cubic-bezier(0.2, 0, 0, 1),
      background-color 0.2s;
  }

  .news-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(73, 104, 189, 0.15); /* テーマカラーの青い影 */
    background-color: #e6edf4; /* ホバー時に少し濃くする */
  }

  .news-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .news-badge {
    background-color: #4968bd; /* テーマカラー */
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 12px;
  }

  .news-date {
    font-size: 0.85rem;
    color: #44474e; /* M3のOn Surface Variant色 */
    font-family: 'Roboto', sans-serif;
  }

  .news-title {
    font-size: 1rem;
    line-height: 1.5;
    margin: 0;
    font-weight: 700;
    flex-grow: 1; /* 余白を埋める */
  }

  .news-icon {
    align-self: flex-end;
    margin-top: 16px;
    color: #4968bd; /* テーマカラー */
    background-color: white;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s;
  }

  .news-card:hover .news-icon {
    transform: translateX(4px); /* ホバーで矢印が少し右に動く */
  }
</style>
