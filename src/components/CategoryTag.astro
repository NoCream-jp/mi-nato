---
interface Props {
  category: string;
}

const { category } = Astro.props;
---

<span class="category-tag">
  {category}
</span>

<style>
  .category-tag {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px; /* 丸みのあるタグ形状 */
    font-size: 0.85rem;
    font-weight: 500;

    color: var(--theme2);
    background-color: var(--theme6);
  }
</style>
