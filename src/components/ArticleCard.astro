---
// src/components/ArticleCard.astro
interface Props {
  href: string;
  title: string;
  date: Date;
  category?: string;
}

const { href, title, date, category } = Astro.props;

// コンポーネント内で日付をフォーマットします
const formattedDate = date.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---

<a 
  href={href} 
  class="group flex items-center justify-between border-b border-zinc-200 pb-3 text-sm transition-all hover:opacity-60"
  data-category={category}
>
  <div class="flex gap-auto items-center truncate mr-1">
    <span class="w-24 shrink-0 text-zinc-400 font-mono text-xs">{formattedDate}</span>
    <span class="mr-3 truncate text-zinc-800 font-normal group-hover:text-zinc-900">
      {title}
    </span>
  </div>
  {category && (
    <span class="hidden lg:block shrink-0 rounded-full bg-zinc-400 px-2 py-0.5 text-[10px] font-normal tracking-wider text-zinc-100">
      {category}
    </span>
  )}
  
</a>