---
import CategoryTag from '../components/CategoryTag.astro';

interface Props {
  href: string;
  thumbnail?: string;
  title: string;
  category: string;
  date?: string;
  class?: string;
}

const { href, title, category, date, class: className } = Astro.props;
---

<a
  href={href}
  class:list={['article-card', className]}
  data-category={category}
>
  <div class="card-eyebrow">
    <CategoryTag category={category} />
  </div>

  <h3 class="card-title">
    {title}
  </h3>

  <time class="card-date">
    {date}
  </time>
</a>

<style>
  .article-card {
    /* レイアウト */
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    max-height: 200px;
    padding: 24px;
    border-radius: 12px;
    text-decoration: none;

    gap: 12px;

    background-color: var(--theme7);
    color: var(--theme1);

    transition:
      background-color 0.2s ease,
      color 0.2s ease;
    transform: 0.2s ease;
  }

  .article-card:hover {
    background-color: var(--theme5);
    transform: scale(1.05);
    transform: translateY(-2px);
  }

  .card-title {
    font-size: clamp(var(--small), 3vw, var(--medium));
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .card-date {
    font-size: 0.9rem;
    opacity: 0.8;
    margin-top: auto;
  }
</style>
