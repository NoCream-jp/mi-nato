<div class="card-container group mx-auto h-64 w-full max-w-sm cursor-pointer perspective-1000px">
  <div 
      class="card-inner relative h-full w-full transition-transform duration-500 transform-3d"
    >
      <div class="absolute inset-0 flex flex-col items-center justify-center rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm backface-hidden">
        
        <img 
          src="/logo.png" 
          alt="Profile" 
          class="mb-4 h-20 w-20 rounded-full border border-zinc-100 object-cover shadow-sm" 
        />
        
        <h3 class="text-lg font-medium text-zinc-900">みなと / minato</h3>
        <p class="mt-1 text-sm text-zinc-500">Machine Learning / Web Developer</p>
        
        <div class="mt-auto flex items-center gap-1 text-xs text-zinc-400 transition-colors group-hover:text-zinc-600">
          <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Click to flip
        </div>
      </div>
  
      <div class="absolute inset-0 flex flex-col justify-center rounded-2xl bg-zinc-900 p-8 text-zinc-100 shadow-sm backface-hidden transform-rotateY(180deg)"
        
        <h3 class="mb-6 w-full border-b border-zinc-700 pb-2 text-center text-sm tracking-widest text-zinc-400">
          PROFILE DETAILS
        </h3>
        
        <div class="flex w-full flex-col gap-4 px-2 text-sm">
          <div class="flex justify-between">
            <span class="text-zinc-400">Birthday</span>
            <span class="tracking-wide">200X.XX.XX</span>
          </div>
          <div class="flex justify-between">
            <span class="text-zinc-400">Location</span>
            <span class="tracking-wide">Wakayama, Japan</span>
          </div>
          <div class="flex justify-between">
            <span class="text-zinc-400">Univ.</span>
            <span class="tracking-wide">Wakayama Univ.</span>
          </div>
        </div>
  
        <div class="mt-8 flex justify-center gap-6">
          <a href="https://github.com/NoCream-jp" target="_blank" class="text-zinc-400 transition-colors hover:text-white" onclick="event.stopPropagation()">
            <span class="sr-only">GitHub</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a href="https://x.com/sXMN1au45a68174" target="_blank" class="text-zinc-400 transition-colors hover:text-white" onclick="event.stopPropagation()">
            <span class="sr-only">X</span>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 4.15H5.044z" />
            </svg>
          </a>
        </div>
        
      </div>
    </div>
  </div>
  
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      const cards = document.querySelectorAll('.card-container');
      
      cards.forEach(card => {
        if (card.dataset.init) return;
        card.dataset.init = "true";
        
        card.addEventListener('click', () => {
          const inner = card.querySelector('.card-inner');
          inner.classList.toggle('[transform:rotateY(180deg)]');
        });
      });
    }, { once: false });
  </script>