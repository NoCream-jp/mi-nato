<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll('.draggable-card');

    cards.forEach(card => {
      if (card.dataset.dragInit) return;
      card.dataset.dragInit = "true";

      const inner = card.querySelector('.card-inner');
      
      let isDragging = false;
      let startX, startY;     // クリック判定用の初期座標
      let currentX = 0, currentY = 0;
      let initialX = 0, initialY = 0;
      let xOffset = 0, yOffset = 0;

      // === ドラッグ開始 ===
      const dragStart = (e) => {
        // aタグ（SNSリンク）をクリックした場合はドラッグを発動させない
        if (e.target.closest('a')) return;

        isDragging = true;
        
        // タッチとマウスで座標取得を分岐
        const clientX = e.type === "touchstart" ? e.touches[0].clientX : e.clientX;
        const clientY = e.type === "touchstart" ? e.touches[0].clientY : e.clientY;
        
        startX = clientX;
        startY = clientY;
        initialX = clientX - xOffset;
        initialY = clientY - yOffset;

        // 持ち上げた演出（影を濃く、少し拡大、最前面へ）
        card.style.zIndex = "50";
        card.classList.add('shadow-2xl', 'scale-105');
        // ドラッグ中はCSSのtransitionを切ってマウスにピタッと吸い付かせる
        card.style.transitionDuration = "0s"; 
      };

      // === ドラッグ中 ===
      const drag = (e) => {
        if (!isDragging) return;
        e.preventDefault(); // スマホでの画面スクロールを防止

        const clientX = e.type === "touchmove" ? e.touches[0].clientX : e.clientX;
        const clientY = e.type === "touchmove" ? e.touches[0].clientY : e.clientY;

        currentX = clientX - initialX;
        currentY = clientY - initialY;
        xOffset = currentX;
        yOffset = currentY;

        // transform: translate3d で実際に動かす（GPU支援でヌルヌル動きます）
        card.style.transform = `translate3d(${currentX}px, ${currentY}px, 0)`;
      };

      // === ドラッグ終了（＆クリック判定） ===
      const dragEnd = (e) => {
        if (!isDragging) return;
        isDragging = false;
        
        card.style.zIndex = "10";
        card.classList.remove('shadow-2xl', 'scale-105');
        card.style.transitionDuration = "300ms";

        let clientX, clientY;

        if (e.type === "touchend") {
          const touch = e.changedTouches[0];
          clientX = touch.clientX;
          clientY = touch.clientY;
        } else {
          clientX = e.clientX;
          clientY = e.clientY;
        }

        const distance = Math.hypot(clientX - startX, clientY - startY);

        if (distance < 10) { // ← 少し緩くするのがポイント
          inner.classList.toggle('[transform:rotateY(180deg)]');
        }
      };

      // イベントリスナーの登録（PC用）
      card.addEventListener("mousedown", dragStart);
      document.addEventListener("mousemove", drag);
      document.addEventListener("mouseup", dragEnd);

      // イベントリスナーの登録（スマホ用）
      card.addEventListener("touchstart", dragStart, { passive: false });
      document.addEventListener("touchmove", drag, { passive: false });
      document.addEventListener("touchend", dragEnd);
    });
  }, { once: false });
</script>