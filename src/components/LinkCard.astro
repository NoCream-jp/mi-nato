---
interface Props {
  title: string;
  username?: string;
  href: string;
}

const { title, username, href } = Astro.props;
---

<a 
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group block w-full rounded-md border border-zinc-200 bg-white p-4 hover:border-zinc-300"
>
  <div class="flex items-center justify-between">
    
    <!-- 左側 -->
    <div class="flex flex-col">
      <span class="text-base font-medium text-zinc-800 group-hover:text-zinc-400">
        {title}
      </span>

      {username && (
        <span class="mt-1 text-xs text-zinc-400">
          {username}
        </span>
      )}
    </div>

    <!-- 右上アイコン -->
    <div class="flex align-center justify-center  text-zinc-700 group-hover:text-zinc-400">
        <svg class="h-5 w-auto" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24"><!-- Icon from Material Symbols by Google - https://github.com/google/material-design-icons/blob/master/LICENSE --><path fill="currentColor" d="M6.4 18L5 16.6L14.6 7H6V5h12v12h-2V8.4z"/></svg>
    </div>

  </div>
</a>