---
interface Props {
  date: Date;
  title: string;
}

const { date, title } = Astro.props;

// 「年」のみフォーマットに変換
const formattedDate = date
  .toLocaleDateString("ja-JP", {
    year: "numeric",
    month: "numeric",
  })
  .replace(/\//g, ".");
---

<div class="accordion-item group">
  <button
    class="hover:text-primary flex w-full cursor-pointer items-center gap-4 py-1 text-left text-black transition-colors"
  >
    <time class="text-gray-500 text-label shrink-0 tracking-widest sm:w-20 text-xs">
      {formattedDate}
    </time>

    <div class="min-w-0 flex-1 text-sm">
      {title}
    </div>

    <div class="ml-4 flex shrink-0 items-center justify-center">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14"></path>
        <path
          d="M12 5v14"
          class="origin-center transition-transform duration-300 group-[.is-open]:scale-y-0"
        ></path>
      </svg>
    </div>
  </button>

  <div
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out group-[.is-open]:grid-rows-[1fr]"
  >
    <div class="overflow-hidden">
      <div
        class="pb-5 text-xs leading-relaxed text-black sm:ml-10 sm:text-base"
      >
        <slot />
      </div>
    </div>
  </div>
</div>

<script>
  function setupAccordions() {
    const accordions = document.querySelectorAll(".accordion-item");
    accordions.forEach((item) => {
      const button = item.querySelector("button");
      if (!button || button.dataset.ready) return;
      button.dataset.ready = "true";

      button.addEventListener("click", () => {
        item.classList.toggle("is-open");
      });
    });
  }
  setupAccordions();
  document.addEventListener("astro:page-load", setupAccordions);
</script>
