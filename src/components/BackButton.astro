---
interface Props {
  href: string;
  label?: string;
}

const { href, label = "戻る" } = Astro.props;
---

<button 
  type="button"
  data-fallback={href}
  class="smart-back-btn group inline-flex items-center gap-2 text-sm tracking-wide text-zinc-400 transition-colors duration-200 hover:text-zinc-950 select-none cursor-pointer bg-transparent border-none p-0"
>
  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4 transition-transform duration-200 ease-out">
    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
  </svg>
  <span class="font-normal">{label}</span>
</button>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const btns = document.querySelectorAll('.smart-back-btn');
    
    btns.forEach(btn => {
      if (btn.dataset.init) return;
      btn.dataset.init = "true";
      
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const fallback = btn.getAttribute('data-fallback');
        
        if (window.history.length > 1) {
          window.history.back();
        } else {
          window.location.href = fallback;
        }
      });
    });
  }, { once: false });
</script>