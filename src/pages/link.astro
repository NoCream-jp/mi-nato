---
import Layout from '../layouts/Layout.astro';
import BackButton from '../components/BackButton.astro'
import Breadcrumbs from '../components/Breadcrumbs.astro'
import LinkCard from '../components/LinkCard.astro';

// パンくず
const breadcrumbItems = [
  { label: "TOP", href: "/" },
  { label: "link" }
];

---

<Layout>
  <main 
    transition:name="card-link" 
    class="mx-auto w-full max-w-4xl bg-white px-6 py-12 md:px-12 md:py-20 min-h-screen rounded-md"
  >
    <Breadcrumbs items={breadcrumbItems} />
    <div class="mb-12 border-b border-zinc-300 pb-5">
      <h1 class="text-2xl font-medium tracking-wide text-zinc-900 md:text-[1.7rem]">
        link
      </h1>
    </div>
    <div class="mb-10 grid grid-cols-2 gap-4 md:grid-cols-3">
      <LinkCard title="GitHub" href="https://github.com/NoCream-jp" />
      <LinkCard title="X" href="https://x.com/sXMN1au45a68174" />
      <LinkCard title="Instagram" href="https://www.instagram.com/koshi2055/?hl=ja" />
      <LinkCard title="LinkedIn" href="https://www.linkedin.com/in/m-hayashi/" />
      <LinkCard title="AtCoder" href="https://atcoder.jp/users/Caffeineholic" />
      <LinkCard title="研究室"  href="https://web.wakayama-u.ac.jp/~kuze/lab/jp/" />
      <LinkCard title="WCPC" href="https://wcpc.pages.dev/" />
      <LinkCard title="Qiita" href="https://qiita.com/_NoCream" />
      <LinkCard title="Zenn" href="https://zenn.dev/nocream" />
      <LinkCard title="note" href="https://note.com/mi_nat0" />
    </div>

    <BackButton href="/" />
  </main>
</Layout>