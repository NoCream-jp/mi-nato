---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TagFilter from '../components/TagFilter.astro';
import BackButton from '../components/BackButton.astro';

const allPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true;
});

// 日付でソート（新しい順）
const sortedPosts = allPosts.sort(
  (a: { data: { date: Date; }; }, b: { data: { date: Date; }; }) => b.data.date.valueOf() - a.data.date.valueOf()
);

// パンくず
const breadcrumbItems = [
  { label: "TOP", href: "/" },
  { label: "blog" }
];

// タグフィルタ用のタグ一覧
const allTags = Array.from(
  new Set(allPosts.map((post: { data: { category: any; }; }) => post.data.category))
) as string[];
---

<Layout>
  <main 
    transition:name="card-blog"
    class="mx-auto w-full max-w-4xl bg-white px-6 py-12 md:px-12 md:py-20 min-h-screen rounded-md"
  >
    <Breadcrumbs items={breadcrumbItems} />
    <TagFilter tags={allTags} />

    <div class="mb-12 border-b border-zinc-300 pb-5">
      <h1 class="text-2xl font-normal tracking-wide text-zinc-900 md:text-[1.7rem]">
        blog
      </h1>
    </div>

    <!-- 記事一覧 -->
    <div class="flex flex-col gap-4 mb-10">
      {sortedPosts.length > 0 ? (
        sortedPosts.map((post: { id: any; data: { title: string; date: Date; category: string | undefined; }; }) => (
          <ArticleCard 
            href={`/blog/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
          />
        ))
      ) : (
        <p class="text-center text-sm text-zinc-400 py-8">
          No articles found.
        </p>
      )}
    </div>

    <BackButton href="/" />

  </main>
</Layout>