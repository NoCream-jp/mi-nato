---
import Layout from '../layouts/Layout.astro';
import ViewMoreButton from '../components/ViewMoreButton.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
// import { Icon } from "astro-icon/components";
import LinkCard from '../components/LinkCard.astro';
import BusinessCard from '../components/BusinessCard.astro';
import ActionLog from '../components/ActionLog.astro';


const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
---

<Layout>
  <div class="px-3">
    <div id="card-container" class="mb-3 columns-1 gap-3 md:columns-2">
      
      <section id="about" data-key="about" transition:name="card-about" class=" will-change-transform break-inside-avoid mb-3 flex w-full flex-col items-center rounded-md bg-white p-5 py-12">
        <h2 class="text-2xl font-normal text-zinc-800">about</h2>
        <BusinessCard />
        <div class="py-10 w-full max-w-md flex flex-col justify-center grow">
          <p class="w-full text-sm leading-relaxed text-zinc-800">
            こんにちは。みなとといいます。和歌山大学の情報学領域で勉強している学生です。研究分野は機械学習です。面白い、美しいと思ったことは何でも勉強します。また趣味でwebアプリ開発やサイトのデザイン、運営を行ったり、競技プログラミングのコンテストに参加しています。ぜひサイトを隅々までご覧ください。
          </p>
        </div>
        <div class="mt-auto">
          <ViewMoreButton href="/about" />
        </div>
      </section>

      <section id="blog" data-key="blog" transition:name="card-blog" class="will-change-transform break-inside-avoid mb-3 flex w-full flex-col items-center rounded-md bg-white px-5 py-12">
        <h2 class="text-2xl font-normal text-zinc-800">blog</h2>
        <div class="py-10 w-full max-w-md flex flex-col justify-center gap-3 grow">
          {0 < latestPosts.length ? (
            latestPosts.map((post) => (
              <ArticleCard 
                href={`/blog/${post.id}`}
                title={post.data.title}
                date={post.data.date}
                category={post.data.category}
              /> 
            ))
          ) : (
            <p class="text-center text-sm text-zinc-400 py-8">No articles found.</p>
          )}
        </div>
        <div class="mt-auto">
          <ViewMoreButton href="/blog" />
        </div>
      </section>

      <!-- <section id="action" data-key="action" transition:name="card-action" class="will-change-transform break-inside-avoid mb-3 flex w-full flex-col items-center rounded-md bg-white p-12">
        <h2 class="text-2xl font-normal text-zinc-800">action</h2>
        <div class="py-10 w-full max-w-md flex flex-col gap-1 grow">
          {
            await Promise.all(
              sortedActions.map(async (action) => {
                const { Content } = await render(action);
                return (
                  <ActionAccordion
                    date={action.data.date}
                    title={action.data.title}
                  >
                    <Content />
                  </ActionAccordion>
                );
              })
            )
          }
        </div>
        <div class="mt-auto">
          <ViewMoreButton href="/action" />
        </div>
      </section> -->

      <section id="action" data-key="action" transition:name="card-action" class="bg-white will-change-transform break-inside-avoid mb-3 flex w-full flex-col items-center rounded-md px-5 py-12">
        <h2 class="text-2xl font-normal text-zinc-800">action</h2>
        <ActionLog limit={3}/>
        <div class="mt-auto">
          <ViewMoreButton href="/action" />
        </div>
      </section>

      <section id="learning" data-key="learning" transition:name="card-learning" class="will-change-transform break-inside-avoid mb-3 flex w-full flex-col items-center rounded-md bg-white px-5 py-12">
        <h2 class=" text-2xl font-normal text-zinc-800">learning</h2>
        <div class="py-10 w-full max-w-md flex flex-col gap-1 grow">
          <ul class="mb-7 w-full max-w-md list-inside list-disc space-y-3 text-sm text-zinc-700">
            <li>強化学習・マルチエージェントシステム</li>
            <li>Svelte / Astro / Tailwind CSS v4</li>
            <li>競技プログラミング (AtCoder / Python / C++)</li>
          </ul>
        </div>
        <div class="mt-auto">
          <ViewMoreButton href="/learning" />
        </div>
      </section>
    </div>
    <section id="link" data-key="link" transition:name="card-link" class="will-change-transform break-inside-avoid mb-3 flex w-full flex-col items-center rounded-md bg-white px-5 py-12">
      <a href="/link">
        <img src="/logo.svg" alt="logo" class="h-20">
      </a>
      <div class="py-10 w-full max-w-md flex flex-col gap-1 grow">
        <LinkCard title="GitHub" username='@NoCream-jp' href="https://github.com/NoCream-jp" />
        <LinkCard title="X" username='@sXMN1au45a68174' href="https://x.com/sXMN1au45a68174" />
        <LinkCard title="Instagram" username='@koshi2055' href="https://www.instagram.com/koshi2055/?hl=ja" />
        <LinkCard title="LinkedIn" username='@m-hayashi' href="https://www.linkedin.com/in/m-hayashi/" />
        <LinkCard title="AtCoder" username="@Caffeineholic" href="https://atcoder.jp/users/Caffeineholic" />
        <LinkCard title="研究室" username='@久世研究室' href="https://web.wakayama-u.ac.jp/~kuze/lab/jp/" />
      </div>
      <div class="text-zinc-400 text-sm">© 2025-2026 mi-nato.com</div>
    </section>
  </div>
</Layout>