---
import { getCollection, type CollectionEntry } from 'astro:content';
import FabMenu from '../../components/FabMenu.astro';
import PopupTerminal from '../../components/PopupTerminal.astro';

export async function getStaticPaths() {
  const actions = await getCollection('actions');
  return actions.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'action'>;
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const fabOptions = [
  {
    label: 'Top',
    iconClass: 'fa-solid fa-angle-up',
    href: '#',
  },
  {
    label: 'Home',
    iconClass: 'fa-solid fa-house',
    href: '/',
  },
  {
    label: 'Share on X',
    iconClass: 'fa-brands fa-x-twitter',
    href: `https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(String(Astro.url))}`,
  },
  {
    label: '?',
    iconClass: 'fa-solid fa-code',
    href: '#terminal',
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{entry.data.title} | mi-nato.com</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles/index.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Gothic+A1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="header js-header">
      <div class="header-right">
        <a class="header-most-right" href="/">Home</a>
      </div>
    </header>

    <PopupTerminal />

    <main class="article-page-container">
      <div class="article-page-left-container">
        <article class="article-content">
          <h1 class="article-title">{entry.data.title}</h1>

          <time class="article-date">
            {entry.data.date.toLocaleDateString('ja-JP')}
          </time>

          {
            entry.data.thumbnail && (
              <div class="article-thumbnail-wrapper">
                <img
                  src={entry.data.thumbnail}
                  alt={entry.data.title}
                  class="article-thumbnail"
                />
              </div>
            )
          }

          <div class="article-body">
            <Content />
          </div>
        </article>
      </div>
    </main>

    <script is:inline src="/scripts/script.js"></script>

    <FabMenu options={fabOptions} />

    <footer class="footer">Copyright ©2026 mi-nato.com</footer>
  </body>
</html>

<style>
  .header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  .article-page-container {
    display: flex;
    flex-direction: column; /* サイドバーがないためカラムレイアウトに */
    align-items: flex-start;
    gap: 40px;
    width: 100%;
    max-width: 1000px;
    margin: 0 auto;
    padding: 40px 80px; /* index.cssのbody背景(theme8)に直置き */
  }

  .article-page-left-container {
    min-width: 0; /* Flexboxのはみ出し防止 */
    flex: 1;
    width: 100%; /* カラムレイアウトのため幅を100%に */
  }

  .article-content {
    display: flex;
    flex-direction: column;
    background-color: var(--white); /* M3のSurfaceとして機能 */
    padding: 64px 56px; /* 読ませるページなので余白は贅沢に */
    border-radius: 32px;
    color: var(--black);
  }

  .article-title {
    color: var(--theme1);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 16px 0; /* marginとgapの併用を避けるためmarginで管理 */
  }

  .article-date {
    color: var(--theme3);
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 32px;
  }

  .article-thumbnail-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 48px;
    background-color: var(--theme8);
  }
  .article-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left top; /* どんな画像でも左上を死守 */
  }

  .article-body {
    line-height: 1.9;
    font-size: 1.05rem;
    color: var(--darkgray); /* 真っ黒を避けて目に優しく */
    overflow-wrap: break-word; /* 長い単語やURLを折り返す */
  }

  .article-body :global(h2) {
    color: var(--theme1);
    margin-top: 2.5em;
    margin-bottom: 1em;
  }
  .article-body :global(p) {
    margin-bottom: 1.5em;
  }
  .article-body :global(img) {
    max-width: 100%;
    height: auto;
  }
  .article-body :global(pre),
  .article-body :global(table) {
    max-width: 100%;
    overflow-x: auto;
  }

  .article-body :global(a.image-link-bg) {
    display: inline-block;
    padding: 1rem;
    border-radius: 12px;
    transition: background-color 0.2s ease;
  }
  .article-body :global(a.image-link-bg:hover) {
    background-color: var(--theme7, #f0f0f0);
  }
  .article-body :global(a.image-link-bg img) {
    display: block;
  }

  @media (max-width: 900px) {
    .article-page-container {
      flex-direction: column;
      gap: 64px;
      padding: 40px 20px;
    }
    .article-page-left-container {
      width: 100%;
    }
    .article-content {
      padding: 32px 20px; /* スマホではPaddingを狭く */
      border-radius: 24px;
    }
  }
</style>
