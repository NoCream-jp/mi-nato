---
import { getCollection } from 'astro:content';

import Layout from '../layouts/Layout.astro';
import BusinessCard from '../components/BusinessCard.astro';
import ImageStack from '../components/ImageStack.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TagFilter from '../components/TagFilter.astro';



// パンくず用
const breadcrumbItems = [
  { label: "TOP", href: "/" },
  { label: "about" }
];

// ImageStack用
const sampleImages = [
  '/assets/cat.webp',
  '/assets/ra-men.webp',
  '/assets/spotify.webp',
];

// 資格データ
const certifications = await getCollection('certification');

// タグ一覧（重複排除）
const allTags = Array.from(
  new Set(certifications.flatMap(c => c.data.tags))
);
console.log(await getCollection("certification"));
---

<Layout title="about | mi-nato">
  <div class="min-h-screen text-zinc-900 selection:bg-zinc-200">
    <div class="mx-auto max-w-4xl px-6 py-24 md:px-12 md:py-32 bg-white rounded-md">

      <Breadcrumbs items={breadcrumbItems} />

      <div class="mb-16 mt-4 border-b border-zinc-200 pb-6">
        <h1 class="text-2xl font-normal tracking-wide md:text-[1.7rem]">
          about
        </h1>
      </div>

      <div class="grid grid-cols-1 items-start gap-14 md:grid-cols-12 md:gap-12">

        <!-- 左 -->
        <div class="md:col-span-5 md:sticky md:top-32">
          <div class="scroll-reveal translate-y-8 opacity-0">
            <BusinessCard />
          </div>
        </div>

        <!-- 右 -->
        <div class="md:col-span-7 flex flex-col gap-24 pt-8 md:pt-0">

          <div class="scroll-reveal translate-y-8 opacity-0 md:delay-150">
            <ImageStack images={sampleImages} />
          </div>

          <!-- bio -->
          <section class="scroll-reveal translate-y-8 opacity-0">
            <h2 class="mb-6 text-xl font-medium tracking-wide">bio</h2>
            <div class="space-y-4 text-[15px] leading-relaxed text-zinc-600">
              こんにちは。みなとといいます。和歌山大学の情報学領域で勉強している学生です。研究分野は機械学習です。面白い、美しいと思ったことは何でも勉強します。また趣味でwebアプリ開発やサイトのデザイン、運営を行ったり、競技プログラミングのコンテストに参加しています。ぜひサイトを隅々までご覧ください。
              最近は、このサイトのデザインと実装にのめりこんでいます。
            </div>
          </section>

          <!-- archievement -->
          <section class="scroll-reveal translate-y-8 opacity-0">
            <h2 class="mb-6 text-xl font-medium tracking-wide">archievement</h2>

            <!-- 既存TagFilterを利用 -->
            <TagFilter tags={allTags} />

            <!-- カード -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {certifications.map(cert => (
                <div
                  class="cert-card cursor-pointer rounded-xl border border-zinc-200 bg-white p-4 transition hover:shadow-md hover:-translate-y-0.5"
                  data-tags={cert.data.tags.join(",")}
                  data-title={cert.data.title}
                  data-issuer={cert.data.issuer}
                  data-date={cert.data.date}
                  data-description={cert.data.description}
                  data-link={cert.data.link ?? "#"}
                >
                  <h3 class="text-[15px] font-medium">
                    {cert.data.title}
                  </h3>
                  <p class="text-xs text-zinc-500 mt-1">
                    {cert.data.issuer} / {cert.data.date}
                  </p>
                </div>
              ))}
            </div>
          </section>

          <section>
            <h2 class="mb-6 text-xl font-medium tracking-wide">favorite</h2>
          </section>

        </div>
      </div>
    </div>
  </div>

  <!-- モーダル -->
  <div id="modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-lg">
      <h3 id="modal-title" class="text-lg font-medium"></h3>
      <p id="modal-meta" class="text-sm text-zinc-500 mt-1"></p>
      <p id="modal-desc" class="mt-4 text-sm text-zinc-600"></p>

      <a id="modal-link" href="#" target="_blank"
        class="mt-4 inline-block text-sm underline text-zinc-700">
        証明を見る
      </a>

      <button id="modal-close"
        class="mt-6 text-sm text-zinc-400 hover:text-zinc-700">
        close
      </button>
    </div>
  </div>
</Layout>

<script>
const setupObserver = () => {
  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.remove('opacity-0', 'translate-y-8');
        entry.target.classList.add('opacity-100', 'translate-y-0');
        obs.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.scroll-reveal').forEach(el => observer.observe(el));
};

const setupModal = () => {
  const cards = document.querySelectorAll<HTMLElement>('.cert-card');
  const modal = document.getElementById('modal');

  const title = document.getElementById('modal-title');
  const meta = document.getElementById('modal-meta');
  const desc = document.getElementById('modal-desc');
  const link = document.getElementById('modal-link');
  const close = document.getElementById('modal-close');

  if (!modal || !title || !meta || !desc || !link || !close) return;

  cards.forEach(card => {
    card.addEventListener('click', (e) => {
      const el = e.currentTarget as HTMLElement;

      title.textContent = el.dataset.title ?? "";
      meta.textContent = `${el.dataset.issuer ?? ""} / ${el.dataset.date ?? ""}`;
      desc.textContent = el.dataset.description ?? "";
      (link as HTMLAnchorElement).href = el.dataset.link ?? "#";

      modal.classList.remove('hidden');
      modal.classList.add('flex');
    });
  });

  close.addEventListener('click', () => {
    modal.classList.add('hidden');
  });

  modal.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.classList.add('hidden');
    }
  });
};

document.addEventListener('astro:page-load', () => {
  setupObserver();
  setupModal();
});

setupObserver();
setupModal();
</script>