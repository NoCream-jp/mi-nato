---
import Layout from '../layouts/Layout.astro';
import BusinessCard from '../components/BusinessCard.astro';
import ImageStack from '../components/ImageStack.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

// パンくず
const breadcrumbItems = [
  { label: "TOP", href: "/" },
  { label: "about" }
];

const sampleImages = [
  '/assets/cat.webp',
  '/assets/ra-men.webp',
  '/assets/spotify.webp',
];
---

<Layout title="about | mi-nato">
  <div class="min-h-screen text-zinc-900 selection:bg-zinc-200">
    <div class="mx-auto max-w-4xl px-6 py-24 md:px-12 md:py-32 bg-white rounded-md">
      <Breadcrumbs items={breadcrumbItems} />

      <div class="mb-16 mt-4 border-b border-zinc-200 pb-6">
        <h1 class="text-2xl font-normal tracking-wide text-zinc-900 md:text-[1.7rem]">
          about
        </h1>
      </div>

      <div class="grid grid-cols-1 items-start gap-14 md:grid-cols-12 md:gap-12">

        <!-- 左 -->
        <div class="md:col-span-5 md:sticky md:top-32 relative z-10">
          <div class="scroll-reveal  ease-out translate-y-8 opacity-0">
            <BusinessCard />
          </div>
        </div>

        <!-- 右 -->
        <div class="md:col-span-7 flex flex-col gap-24 pt-8 md:pt-0">

          <div class="scroll-reveal  ease-out translate-y-8 opacity-0 md:delay-150">
            <ImageStack images={sampleImages} />
          </div>

          <section class="scroll-reveal  ease-out translate-y-8 opacity-0">
            <h2 class="mb-6 text-xl font-medium tracking-wide">Background & Research</h2>
            <div class="space-y-4 text-[15px] leading-relaxed text-zinc-600 font-light">
              <p>
                和歌山大学で情報学を専攻している6セメスターの学生です。現在は強化学習を用いたマルチエージェントシステム、特にUAV（無人航空機）の経路計画最適化について研究を進めています。
              </p>
              <p>
                複雑な環境下でエージェントがいかに協調し、最適な解を導き出すかというアルゴリズムの深淵に魅力を感じています。
              </p>
            </div>
          </section>

          <section class="scroll-reveal  ease-out translate-y-8 opacity-0">
            <h2 class="mb-6 text-xl font-medium tracking-wide">Engineering</h2>
            <div class="space-y-4 text-[15px] leading-relaxed text-zinc-600 font-light">
              <p>
                Web開発では、AstroやSvelteを用いたコンポーネント指向のモダンなフロントエンド構築を行っています。スタイリングはTailwind CSS v4を軸に、モノクロームでミニマルなUI設計を好みます。
              </p>
              <p>
                また、学生団体「Waka-topia」や競技プログラミングサークル（WCPC）での活動を通じ、チーム開発やアルゴリズムの研鑽（AtCoder / Python / C++）にも継続的に取り組んでいます。バックエンドにはSupabaseやFirebaseを活用し、堅牢なシステム構築を目指しています。
              </p>
            </div>
          </section>

          <section class="scroll-reveal  ease-out translate-y-8 opacity-0">
            <h2 class="mb-6 text-xl font-medium tracking-wide">Lifestyle</h2>
            <div class="space-y-4 text-[15px] leading-relaxed text-zinc-600 font-light">
              <p>
                日常では、マキネッタで淹れるスペシャルティコーヒーの香りを楽しみながらコードを書く時間が好きです。
              </p>
              <p>
                語源や言語学のニュアンスの違いを探求すること、そしてワイドトラウザーやトレンチコートを取り入れた、シンプルでモダンなモノトーンファッションを身に纏うことが、私にとっての美学の表現です。
              </p>
            </div>
          </section>

        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Intersection Observerを用いたスクロール連動のフェードイン処理
  const setupObserver = () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15 // 要素が15%画面に入ったら発火
    };

    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          // opacity-0 と translate-y-8 を外して、元の位置・不透明度にふわっと戻す
          entry.target.classList.remove('opacity-0', 'translate-y-8');
          entry.target.classList.add('opacity-100', 'translate-y-0');
          
          // 一度発火したら監視を解除（上にスクロールして戻っても再表示させない）
          obs.unobserve(entry.target);
        }
      });
    }, observerOptions);

    const elements = document.querySelectorAll('.scroll-reveal');
    elements.forEach(el => observer.observe(el));
  };

  // AstroのView Transitions（SPAルーティング）対応
  document.addEventListener('astro:page-load', setupObserver);
  
  // 初回ロード用
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupObserver);
  } else {
    setupObserver();
  }
</script>