---
import { getCollection, type CollectionEntry } from 'astro:content';
import CategoryTag from '../../components/CategoryTag.astro';
import ContentNavigation from '../../components/ContentNavigation.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import FabMenu from '../../components/FabMenu.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('article');
  const sortedEntries = blogEntries.sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  return sortedEntries.map((entry, index) => {
    const prevEntry =
      index < sortedEntries.length - 1 ? sortedEntries[index + 1] : undefined;
    const nextEntry = index > 0 ? sortedEntries[index - 1] : undefined;
    return {
      params: { slug: entry.slug },
      props: { entry, prevEntry, nextEntry },
    };
  });
}

interface Props {
  entry: CollectionEntry<'article'>;
  prevEntry?: CollectionEntry<'article'>;
  nextEntry?: CollectionEntry<'article'>;
}

const { entry, prevEntry, nextEntry } = Astro.props;
const { Content } = await entry.render();

const allArticles = await getCollection('article');
const sortedArticles = allArticles.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// 表示されている記事からユニークなカテゴリーを抽出
const categories = [
  ...new Set(sortedArticles.map((article) => article.data.category)),
];

const fabOptions = [
  {
    label: 'Top',
    iconClass: 'fa-solid fa-angle-up',
    href: '#',
  },
  {
    label: 'Home',
    iconClass: 'fa-solid fa-house',
    href: '/',
  },
  {
    label: 'Share on X',
    iconClass: 'fa-brands fa-x-twitter',
    href: `https://twitter.com/intent/tweet?text=${encodeURIComponent(entry.data.title)}&url=${encodeURIComponent(String(Astro.url))}`,
  },
  {
    label: '?',
    iconClass: 'fa-solid fa-code',
    href: '#terminal',
  },
];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{entry.data.title} | mi-nato.com</title>
    <link rel="icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles/index.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Merriweather:wght@300;400;700;900&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Gothic+A1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="header js-header">
      <div class="header-right">
        <a class="header-most-right" href="/">Home</a>
      </div>
    </header>

    <main class="article-page-container">
      <div class="article-page-left-container">
        <article class="article-content">
          <div class="article-eyebrow">
            <CategoryTag category={entry.data.category} />
          </div>

          <h1 class="article-title">{entry.data.title}</h1>

          <time class="article-date">
            {entry.data.date.toLocaleDateString('ja-JP')}
          </time>

          <!-- {entry.data.thumbnail && (
            <div class="article-thumbnail-wrapper">
              <img
                src={entry.data.thumbnail}
                alt={entry.data.title}
                class="article-thumbnail"
              />
            </div>
          )} -->

          <div class="article-body">
            <Content />
          </div>

          <div class="article-navigation-wrapper">
            <ContentNavigation
              prevUrl={prevEntry ? `/article/${prevEntry.slug}` : undefined}
              prevText={prevEntry ? prevEntry.data.title : undefined}
              nextUrl={nextEntry ? `/article/${nextEntry.slug}` : undefined}
              nextText={nextEntry ? nextEntry.data.title : undefined}
            />
          </div>
        </article>
      </div>

      <aside class="article-sidebar">
        <h2 class="sidebar-title">Recent Articles</h2>
        <div class="toolbar">
          <div class="filter-dropdown">
            <button id="tag-filter-button" class="filter-button"
              >Tag <i class="fa-solid fa-caret-down"></i></button
            >
            <div id="tag-dropdown-content" class="dropdown-content">
              <button class="dropdown-item" data-category="all">All</button>
              {
                categories.map((cat) => (
                  <button class="dropdown-item" data-category={cat}>
                    {cat}
                  </button>
                ))
              }
            </div>
          </div>
        </div>

        <div class="sidebar-list">
          {
            sortedArticles.slice(0).map((article) => (
              <div
                class="article-filter-item"
                data-category={article.data.category}
                style="display: contents;"
              >
                <ArticleCard
                  href={`/article/${article.slug}`}
                  thumbnail={article.data.thumbnail}
                  title={article.data.title}
                  category={article.data.category}
                  date={article.data.date.toLocaleDateString('ja-JP')}
                />
              </div>
            ))
          }
        </div>
      </aside>
    </main>

    <FabMenu options={fabOptions} />

    <script is:inline src="/scripts/script.js"></script>
    <footer class="footer">Copyright ©2026 mi-nato.com</footer>
  </body>
</html>

<style>
  .header {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
  }

  .article-page-container {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 40px;
    width: 100%;
    margin: 0 auto;
    padding: 40px 80px; /* index.cssのbody背景(theme8)に直置き */
  }

  .article-page-left-container {
    min-width: 0; /* Flexboxのはみ出し防止 */
    flex: 1;
  }

  .article-sidebar {
    width: 320px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    position: sticky; /* スクロールに追従させる */
    top: 120px; /* ヘッダーの高さ + 余白 */
  }

  /* =========================================
     記事メインコンテンツ (Surface)
     ========================================= */
  .article-content {
    display: flex;
    flex-direction: column;
    background-color: var(--white); /* M3のSurfaceとして機能 */
    padding: 64px 56px; /* 読ませるページなので余白は贅沢に */
    border-radius: 32px;
    color: var(--black);
  }

  /* アイブロウレイアウトの余白管理 */
  .article-eyebrow {
    margin-bottom: 16px;
  }

  .article-title {
    color: var(--theme1);
    font-size: clamp(28px, 4vw, 36px);
    font-weight: 800;
    line-height: 1.4;
    margin: 0 0 16px 0; /* marginとgapの併用を避けるためmarginで管理 */
  }

  .article-date {
    color: var(--theme3);
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 32px;
  }

  /* サムネイル画像 */
  .article-thumbnail-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 48px;
    background-color: var(--theme8);
  }
  .article-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: left top; /* どんな画像でも左上を死守 */
  }

  /* 記事本文 */
  .article-body {
    line-height: 1.9;
    font-size: 1.05rem;
    color: var(--darkgray); /* 真っ黒を避けて目に優しく */
    overflow-wrap: break-word; /* 長い単語やURLを折り返す */
  }

  /* 本文内の見出しや段落の余白調整（必要に応じて） */
  .article-body :global(h2) {
    color: var(--theme1);
    margin-top: 2.5em;
    margin-bottom: 1em;
  }
  .article-body :global(p) {
    margin-bottom: 1.5em;
  }
  /* 画像がはみ出さないようにする */
  .article-body :global(img) {
    max-width: 100%;
    height: auto;
  }
  /* 警告・情報ボックスのスタイル */
  .article-body :global(.alert) {
    padding: 1em 1.5em;
    margin: 1.5em 0;
    border-left: 5px solid #ccc;
    border-radius: 4px;
    background-color: #f9f9f9;
  }
  .article-body :global(.alert.info) {
    border-color: var(--theme4); /* 変数を利用したテーマカラー */
    background-color: #eef7ff;
  }
  .article-body :global(.alert.warning) {
    border-color: #ffc107; /* 警告を示す黄色 */
    background-color: #fffbe6;
  }

  /* コードブロックなどがはみ出す場合は横スクロールさせる */
  .article-body :global(table) {
    max-width: 100%;
    overflow-x: auto;
  }
  .article-body :global(pre) {
    background-color: #2d2d2d; /* ダークな背景色 */
    color: #f8f8f2; /* 見やすい明るい文字色 */
    padding: 1.5em;
    border-radius: 8px;
    overflow-x: auto;
  }

  /* 文中のインラインコードスニペットのスタイル */
  .article-body :global(code) {
    background-color: var(--theme8, #f4f4f4); /* 薄いグレーの背景 */
    color: #e83e8c; /* 少し目立つピンク・赤系の色 */
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-family: 'Courier New', Courier, monospace;
  }
  /* preタグ（コードブロック）内のcodeタグはインラインスタイルをリセット */
  .article-body :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
  }

  .article-navigation-wrapper {
    margin-top: 80px;
    border-top: 1px solid var(--theme7); /* 記事の終わりを示す線 */
    padding-top: 16px;
  }

  /* =========================================
     サイドバー
     ========================================= */
  .sidebar-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--theme1);
    margin: 0;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--theme7);
  }

  .sidebar-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* =========================================
     レスポンシブ (スマホ・タブレット)
     ========================================= */
  @media (max-width: 900px) {
    .article-page-container {
      flex-direction: column;
      gap: 64px;
      padding: 40px 20px;
    }
    .article-page-left-container {
      width: 100%;
    }
    .article-sidebar {
      margin-top: 60px;
      width: 100%;
      position: static; /* スマホでは追従を解除 */
    }
    .article-content {
      padding: 32px 20px; /* スマホではPaddingを狭く */
      border-radius: 24px;
    }
    .article-thumbnail-wrapper {
      margin-bottom: 32px;
    }
  }
</style>
